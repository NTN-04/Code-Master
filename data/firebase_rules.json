{
  "rules": {
    "courses": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",

      "$courseId": {
        ".validate": "newData.hasChildren(['title', 'description', 'level', 'category', 'duration', 'lessons', 'status'])",

        "title": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },

        "description": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
        },

        "level": {
          ".validate": "newData.isString() && (newData.val() == 'beginner' || newData.val() == 'intermediate' || newData.val() == 'advanced')"
        },

        "category": {
          ".validate": "newData.isString() && (newData.val() == 'web' || newData.val() == 'mobile' || newData.val() == 'data' || newData.val() == 'ai')"
        },

        "duration": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },

        "lessons": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },

        "status": {
          ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'inactive' || newData.val() == 'draft')"
        },

        "progress": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },

        "image": {
          ".validate": "newData.isString()"
        },

        "createdAt": {
          ".validate": "newData.isString()"
        },

        "updatedAt": {
          ".validate": "newData.isString()"
        }
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('users').child(auth.uid).child('role').val() == 1)",
        ".write": "auth != null && (auth.uid == $userId || root.child('users').child(auth.uid).child('role').val() == 1)",
        ".validate": "newData.hasChildren(['name', 'email', 'role', 'status'])",

        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },

        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
        },

        "role": {
          ".validate": "newData.isNumber() && (newData.val() == 1 || newData.val() == 2)"
        },

        "status": {
          ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'inactive' || newData.val() == 'banned')"
        },

        "avatar": {
          ".validate": "newData.isString()"
        },

        "phone": {
          ".validate": "newData.isString()"
        },

        "address": {
          ".validate": "newData.isString()"
        },

        "bio": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },

        "skills": {
          "$skillId": {
            ".validate": "newData.isString()"
          }
        },

        "joinedAt": {
          ".validate": "newData.isString()"
        },

        "lastLoginAt": {
          ".validate": "newData.isString()"
        }
      }
    },

    "resources": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",

      "$resourceId": {
        ".validate": "newData.hasChildren(['title', 'type', 'category', 'status'])",

        "title": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },

        "description": {
          ".validate": "newData.isString() && newData.val().length <= 1000"
        },

        "type": {
          ".validate": "newData.isString() && (newData.val() == 'document' || newData.val() == 'video' || newData.val() == 'audio' || newData.val() == 'link')"
        },

        "category": {
          ".validate": "newData.isString() && (newData.val() == 'tutorial' || newData.val() == 'reference' || newData.val() == 'example' || newData.val() == 'tool')"
        },

        "status": {
          ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'inactive')"
        },

        "url": {
          ".validate": "newData.isString()"
        },

        "size": {
          ".validate": "newData.isString()"
        },

        "downloads": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "createdAt": {
          ".validate": "newData.isString()"
        },

        "updatedAt": {
          ".validate": "newData.isString()"
        }
      }
    },
    "progress": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('users').child(auth.uid).child('role').val() == 1)",
        ".write": "auth != null && (auth.uid == $userId || root.child('users').child(auth.uid).child('role').val() == 1)",
        "$courseId": {
          ".validate": "newData.hasChildren(['courseId', 'userId', 'progress', 'status'])",

          "courseId": {
            ".validate": "newData.isString()"
          },

          "userId": {
            ".validate": "newData.isString()"
          },

          "progress": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
          },

          "status": {
            ".validate": "newData.isString() && (newData.val() == 'not_started' || newData.val() == 'in_progress' || newData.val() == 'completed')"
          },

          "startedAt": {
            ".validate": "newData.isString()"
          },

          "completedAt": {
            ".validate": "newData.isString()"
          },

          "lastAccessedAt": {
            ".validate": "newData.isString()"
          },

          "timeSpent": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "completedLessons": {
            "$lessonId": {
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },

    "activities": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",
      ".write": "auth != null",

      "$activityId": {
        ".validate": "newData.hasChildren(['userId', 'action', 'timestamp'])",

        "userId": {
          ".validate": "newData.isString()"
        },

        "action": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },

        "details": {
          ".validate": "newData.isString()"
        },

        "timestamp": {
          ".validate": "newData.isString()"
        },

        "ipAddress": {
          ".validate": "newData.isString()"
        },

        "userAgent": {
          ".validate": "newData.isString()"
        }
      }
    },

    "settings": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",

      "siteName": {
        ".validate": "newData.isString() && newData.val().length > 0"
      },

      "siteDescription": {
        ".validate": "newData.isString()"
      },

      "contactEmail": {
        ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
      },

      "maintenanceMode": {
        ".validate": "newData.isBoolean()"
      },

      "registrationEnabled": {
        ".validate": "newData.isBoolean()"
      },

      "maxFileSize": {
        ".validate": "newData.isNumber() && newData.val() > 0"
      },

      "allowedFileTypes": {
        "$fileType": {
          ".validate": "newData.isString()"
        }
      }
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('users').child(auth.uid).child('role').val() == 1)",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",
        "$notificationId": {
          ".validate": "newData.hasChildren(['title', 'message', 'type', 'status', 'createdAt'])",

          "title": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },

          "message": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },

          "type": {
            ".validate": "newData.isString() && (newData.val() == 'info' || newData.val() == 'warning' || newData.val() == 'error' || newData.val() == 'success')"
          },

          "status": {
            ".validate": "newData.isString() && (newData.val() == 'unread' || newData.val() == 'read')"
          },

          "link": {
            ".validate": "newData.isString()"
          },

          "createdAt": {
            ".validate": "newData.isString()"
          },

          "readAt": {
            ".validate": "newData.isString()"
          }
        }
      }
    },

    "analytics": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",

      "daily": {
        "$date": {
          "users": {
            "total": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "active": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "new": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          },

          "courses": {
            "total": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "completed": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "started": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          },

          "resources": {
            "total": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "downloads": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      }
    },

    "reviews": {
      ".read": true,
      ".write": "auth != null",

      "$courseId": {
        "$reviewId": {
          ".validate": "newData.hasChildren(['userId', 'courseId', 'rating', 'comment', 'createdAt'])",

          "userId": {
            ".validate": "newData.isString() && newData.val() == auth.uid"
          },

          "courseId": {
            ".validate": "newData.isString()"
          },

          "rating": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
          },

          "comment": {
            ".validate": "newData.isString() && newData.val().length <= 1000"
          },

          "createdAt": {
            ".validate": "newData.isString()"
          },

          "updatedAt": {
            ".validate": "newData.isString()"
          }
        }
      }
    },

    "comments": {
      ".read": true,
      "$courseId": {
        "$lessonId": {
          ".write": "auth != null",
          "$commentId": {
            ".validate": "newData.hasChildren(['userId', 'userName', 'content', 'timestamp', 'status'])",

            "userId": {
              ".validate": "newData.isString() && newData.val() == auth.uid"
            },

            "userName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
            },

            "userAvatar": {
              ".validate": "newData.isString()"
            },

            "content": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 2000"
            },

            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },

            "likes": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },

            "dislikes": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },

            "reports": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },

            "status": {
              ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'hidden' || newData.val() == 'deleted')"
            },

            "isEdited": {
              ".validate": "newData.isBoolean()"
            },

            "editedAt": {
              ".validate": "newData.isNumber() || newData.val() == null"
            },

            "replies": {
              "$replyId": {
                ".validate": "newData.hasChildren(['userId', 'userName', 'content', 'timestamp', 'status', 'parentId'])",

                "userId": {
                  ".validate": "newData.isString() && newData.val() == auth.uid"
                },

                "userName": {
                  ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
                },

                "userAvatar": {
                  ".validate": "newData.isString()"
                },

                "content": {
                  ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 2000"
                },

                "timestamp": {
                  ".validate": "newData.isNumber() && newData.val() <= now"
                },

                "likes": {
                  ".validate": "newData.isNumber() && newData.val() >= 0"
                },

                "dislikes": {
                  ".validate": "newData.isNumber() && newData.val() >= 0"
                },

                "reports": {
                  ".validate": "newData.isNumber() && newData.val() >= 0"
                },

                "status": {
                  ".validate": "newData.isString() && (newData.val() == 'active' || newData.val() == 'hidden' || newData.val() == 'deleted')"
                },

                "isEdited": {
                  ".validate": "newData.isBoolean()"
                },

                "editedAt": {
                  ".validate": "newData.isNumber() || newData.val() == null"
                },

                "parentId": {
                  ".validate": "newData.isString() && newData.val().length > 0"
                }
              }
            }
          }
        }
      }
    },

    "commentVotes": {
      ".read": true,
      "$commentId": {
        "$userId": {
          ".write": "auth != null && $userId == auth.uid",
          ".validate": "newData.isString() && (newData.val() == 'like' || newData.val() == 'dislike')"
        }
      }
    },

    "commentReports": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() == 1",
      "$commentId": {
        "$userId": {
          ".write": "auth != null && $userId == auth.uid",
          ".validate": "newData.hasChildren(['reason', 'timestamp'])",

          "reason": {
            ".validate": "newData.isString() && (newData.val() == 'spam' || newData.val() == 'inappropriate' || newData.val() == 'harassment' || newData.val() == 'other')"
          },

          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() <= now"
          },

          "description": {
            ".validate": "newData.isString() && newData.val().length <= 500"
          }
        }
      }
    }
  }
}
