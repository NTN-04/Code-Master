{
  "rules": {
    "courses": {
      ".read": true,
      ".write": "auth != null && auth.token.admin == true"
    },

    "categories": {
      ".read": true,
      ".write": "auth != null && auth.token.admin == true"
    },

    "learningPaths": {
      ".read": true,
      ".write": "auth != null && auth.token.admin == true"
    },

    "resources": {
      ".read": true,
      ".write": "auth != null && auth.token.admin == true"
    },

    "settings": {
      ".read": true,
      ".write": "auth != null && auth.token.admin == true"
    },

    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".write": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".validate": "newData.hasChildren(['id', 'email', 'username', 'avatar', 'role', 'bio', 'createAt'])",

        "id": {
          ".validate": "newData.isString() && newData.val() == $userId"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}$/i)"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 30"
        },
        "bio": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "avatar": {
          ".validate": "newData.isString()"
        },
        "role": {
          ".validate": "newData.isNumber()"
        },
        "createAt": {
          ".validate": "newData.isString()"
        }
      }
    },

    "userProgress": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".write": "auth != null && (auth.uid == $userId || auth.token.admin == true)",

        "courses": {
          "$courseId": {
            "completedLessons": {
              ".validate": "newData.hasChildren() || newData.val() == null"
            },
            "progress": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
            },
            "timeSpent": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "lastAccessed": {
              ".validate": "newData.isString()"
            }
          }
        },

        "totalLessonsCompleted": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "totalTimeSpent": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "lastActiveDate": {
          ".validate": "newData.isString()"
        }
      }
    },

    "courseEnrollments": {
      "$courseId": {
        ".read": true,
        "$userId": {
          ".write": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
          ".validate": "newData.hasChildren(['enrolledAt']) && newData.child('enrolledAt').isString()"
        }
      }
    },

    "courseReviews": {
      "$courseId": {
        ".read": true,
        "$reviewId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['userId', 'rating', 'comment', 'createdAt']) && newData.child('userId').isString() && newData.child('rating').isNumber() && newData.child('rating').val() >= 1 && newData.child('rating').val() <= 5 && newData.child('comment').isString() && newData.child('comment').val().length <= 1000 && newData.child('createdAt').isString()",

          "userId": {
            ".validate": "newData.val() == auth.uid"
          }
        }
      }
    },

    "statistics": {
      ".read": "auth != null && auth.token.admin == true",
      ".write": "auth != null && auth.token.admin == true"
    },

    "notifications": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".write": "auth != null && auth.token.admin == true",

        "$notificationId": {
          ".validate": "newData.hasChildren(['title', 'message', 'type', 'isRead', 'createdAt']) && newData.child('title').isString() && newData.child('message').isString() && newData.child('type').isString() && newData.child('isRead').isBoolean() && newData.child('createdAt').isString()"
        }
      }
    },

    "admin": {
      ".read": "auth != null && auth.token.admin == true",
      ".write": "auth != null && auth.token.admin == true"
    },

    "courseContent": {
      "$courseId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.admin == true",

        "lessons": {
          "$lessonId": {
            ".validate": "newData.hasChildren(['id', 'title', 'content', 'order']) && newData.child('id').isString() && newData.child('title').isString() && newData.child('content').isString() && newData.child('order').isNumber()"
          }
        },

        "videos": {
          "$videoId": {
            ".validate": "newData.hasChildren(['id', 'title', 'url', 'duration', 'order']) && newData.child('id').isString() && newData.child('title').isString() && newData.child('url').isString() && newData.child('duration').isNumber() && newData.child('order').isNumber()"
          }
        },

        "assignments": {
          "$assignmentId": {
            ".validate": "newData.hasChildren(['id', 'title', 'description', 'order']) && newData.child('id').isString() && newData.child('title').isString() && newData.child('description').isString() && newData.child('order').isNumber()"
          }
        }
      }
    },

    "userSubmissions": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".write": "auth != null && auth.uid == $userId",

        "$courseId": {
          "$assignmentId": {
            ".validate": "newData.hasChildren(['submissionText', 'submittedAt']) && newData.child('submissionText').isString() && newData.child('submittedAt').isString()"
          }
        }
      }
    },

    "certificates": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.admin == true)",
        ".write": "auth != null && auth.token.admin == true",

        "$certificateId": {
          ".validate": "newData.hasChildren(['courseId', 'issuedAt', 'certificateUrl']) && newData.child('courseId').isString() && newData.child('issuedAt').isString() && newData.child('certificateUrl').isString()"
        }
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
